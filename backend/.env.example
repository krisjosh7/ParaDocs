# Copy to backend/.env and fill in values. backend/.env is gitignored.
GROQ_API_KEY=
# Optional: defaults to llama-3.3-70b-versatile (see Groq console for available models)
# GROQ_MODEL=llama-3.3-70b-versatile
# Timeline fork analysis (same-day conflicts): set to 0/false/no to skip LLM on rebuild (faster, no API use)
# PARADOCS_TIMELINE_BRANCH_LLM=1
